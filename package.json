{
  "name": "sanity-template-nuxt-clean",
  "description": "Sanity + Nuxt: A Powerful Website Starter with Real-time Visual Editing",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:next": "npm run dev --workspace=frontend",
    "dev:studio": "npm run dev --workspace=studio",
    "import-sample-data": "cd studio && sanity dataset import sample-data.tar.gz --replace",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "npm run test --workspace=frontend",
    "prepare": "husky"
  },
  "keywords": [
    "Sanity",
    "Nuxt",
    "Headless CMS",
    "Visual Editing",
    "Live Content API (LCAPI)",
    "Real-time"
  ],
  "bugs": {
    "url": "https://github.com/sanity-io/sanity-template-nuxt-clean/issues"
  },
  "homepage": "https://github.com/sanity-io/sanity-template-nuxt-clean#readme",
  "workspaces": [
    "studio",
    "frontend"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5"
  }
}
