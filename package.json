{
  "name": "sanity-template-nuxt-clean",
  "description": "Sanity + Nuxt: A Powerful Website Starter with Real-time Visual Editing",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:next": "npm run dev --workspace=frontend",
    "dev:studio": "npm run dev --workspace=studio",
    "import-sample-data": "cd studio && sanity dataset import sample-data.tar.gz --replace",
    "lint": "biome check .",
    "lint:semgrep": "semgrep scan --config auto .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "npm run test --workspace=frontend",
    "audit": "npm audit --audit-level=high",
    "commit": "cz",
    "prepare": "husky"
  },
  "keywords": [
    "Sanity",
    "Nuxt",
    "Headless CMS",
    "Visual Editing",
    "Live Content API (LCAPI)",
    "Real-time"
  ],
  "bugs": {
    "url": "https://github.com/sanity-io/sanity-template-nuxt-clean/issues"
  },
  "homepage": "https://github.com/sanity-io/sanity-template-nuxt-clean#readme",
  "workspaces": [
    "studio",
    "frontend"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,ts,vue,css,json}": "biome check --no-errors-on-unmatched"
  }
}
